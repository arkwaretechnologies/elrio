EMAIL_FROM=
EMAIL_HOST=
EMAIL_PASS=
EMAIL_PORT=
EMAIL_RECIPIENT=
EMAIL_USER=

# Server-only: full service account JSON as one line (use .env.local — never commit real values)
FIREBASE_SERVICE_ACCOUNT_KEY=

GOOGLE_GENAI_API_KEY=

# Firebase client (from Firebase Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Logo: optional override URL (default is `/El Rio Logo.png` from `public/`)
NEXT_PUBLIC_APP_LOGO_URL=
# Set to "true" to use Firebase Storage `El Rio Logo Transparent.png` instead of the local file
NEXT_PUBLIC_ENABLE_FIREBASE_STORAGE_LOGO=

# EOD / outbound email (writes to Firestore `mail` when using Trigger Email). Leave unset or false to disable.
# NEXT_PUBLIC_EMAIL_OUTBOUND_ENABLED=true

# Copy Firestore from old project → El Rio (paths to two different *-firebase-adminsdk-*.json files)
# FIRESTORE_MIGRATE_SOURCE_KEY=./other-project-adminsdk.json
# FIRESTORE_MIGRATE_DEST_KEY=./el-rio-16c18-firebase-adminsdk-xxxxx.json
